<!DOCTYPE html>
<html>
<head>
    <title>Login</title>
</head>
<body>

    <h1>Login</h1>

    <form action="/login" method="POST">

        <input
            type="email"
            name="email"
            placeholder="Email"
            required
        >

        <br><br>

        <input
            type="password"
            name="senha"
            placeholder="Senha"
            required
        >

        <br><br>

        <button type="submit">
            Entrar
        </button>

    </form>

</body>
</html>