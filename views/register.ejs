<!DOCTYPE html>
<html>
<head>
    <title>Cadastro</title>
</head>
<body>

    <h1>Cadastro de Usuário</h1>

    <form action="/register" method="POST">

        <input
            type="text"
            name="nome"
            placeholder="Nome"
            required
        >

        <br><br>

        <input
            type="email"
            name="email"
            placeholder="Email"
            required
        >

        <br><br>

        <input
            type="password"
            name="senha"
            placeholder="Senha"
            required
        >

        <br><br>

        <button type="submit">
            Cadastrar
        </button>

    </form>

</body>
</html>
